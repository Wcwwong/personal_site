---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  type?: "website" | "article";
  ogImage?: string;
}

const {
  title = "Willy W.",
  description = "I build real systems with AI as a one-person engineering team.",
  type = "website",
  ogImage = "/og-default.png",
} = Astro.props;

const navItems = [
  { label: "Home", href: "/" },
  { label: "About", href: "/about" },
  { label: "Projects", href: "/projects" },
  { label: "Blog", href: "/blog" },
  { label: "AI Toolkit", href: "/toolkit" },
  { label: "Contact", href: "/contact" },
];

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL(ogImage, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="Willy W." />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <!-- Cloudflare Web Analytics: paste beacon snippet here after first deploy (token from CF dashboard) -->
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <div class="wrap">
        <nav class="site-nav" aria-label="Primary navigation">
          <a class="site-logo" href="/">~/willy</a>
          <div class="nav-links">
            {
              navItems.map((item) => (
                <a
                  href={item.href}
                  aria-current={currentPath === item.href ? "page" : undefined}
                >
                  {item.label}
                </a>
              ))
            }
          </div>
        </nav>
      </div>
    </header>

    <main class="site-main wrap" id="main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="wrap footer-row">
        <span>&copy; 2026 Willy W.</span>
        <div class="footer-links">
          <a href="https://github.com/Wcwwong">GitHub</a>
          <a href="mailto:wcwwong.ucd@gmail.com">Email</a>
          <a href="/rss.xml">RSS</a>
        </div>
      </div>
    </footer>
  </body>
</html>
