---
import Base from "../layouts/Base.astro";
import { formatMonth, getPosts } from "../lib/content";

const posts = await getPosts();
---

<Base
  title="Writing | Willy W."
  description="Writing by Willy W. on AI-native building, projects, and lessons from shipped systems."
>
  <div class="page-hero">
    <p class="kicker">writing</p>
    <h1>Writing</h1>
    <p>
      Markdown-backed notes on AI-assisted development, project lessons, and honest postmortems.
    </p>
  </div>

  <section aria-labelledby="post-list-title">
    <div class="sec-head">
      <h2 id="post-list-title">Posts</h2>
    </div>
    <div class="posts">
      {
        posts.map((post) => (
          <div class="post">
            <div class="post-main">
              <a href={`/blog/${post.id}/`}>{post.data.title}</a>
              <div class="post-tags">
                {post.data.tags.map((tag) => (
                  <a class="tag-chip" href={`/blog/tag/${tag}/`}>{tag}</a>
                ))}
              </div>
            </div>
            <time datetime={formatMonth(post.data.pubDate)}>{formatMonth(post.data.pubDate)}</time>
          </div>
        ))
      }
    </div>
  </section>
</Base>
