---
import Base from "../../../layouts/Base.astro";
import { formatMonth, getPosts } from "../../../lib/content";

export async function getStaticPaths() {
  const allPosts = await getPosts();
  const tags = Array.from(new Set(allPosts.flatMap((post) => post.data.tags)));

  return tags.map((tag) => ({
    params: { tag },
    props: { tag, posts: allPosts.filter((post) => post.data.tags.includes(tag)) },
  }));
}

const { tag, posts } = Astro.props;
---

<Base
  title={`Posts tagged ${tag} | Willy W.`}
  description={`Writing tagged ${tag} by Willy W.`}
>
  <div class="page-hero">
    <p class="kicker">tag</p>
    <h1>Posts tagged {tag}</h1>
    <p>Filtered notes from the writing archive.</p>
  </div>

  <section aria-labelledby="tag-posts-title">
    <div class="sec-head">
      <h2 id="tag-posts-title">Posts</h2>
      <a href="/blog">all posts &rarr;</a>
    </div>
    <div class="posts">
      {
        posts.map((post) => (
          <div class="post">
            <div class="post-main">
              <a href={`/blog/${post.id}/`}>{post.data.title}</a>
              <div class="post-tags">
                {post.data.tags.map((postTag) => (
                  <a class="tag-chip" href={`/blog/tag/${postTag}/`}>{postTag}</a>
                ))}
              </div>
            </div>
            <time datetime={formatMonth(post.data.pubDate)}>{formatMonth(post.data.pubDate)}</time>
          </div>
        ))
      }
    </div>
  </section>
</Base>
