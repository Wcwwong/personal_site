---
import Base from "../layouts/Base.astro";
import {
  formatMonth,
  getFeaturedProjects,
  getLatestPosts,
  projectStatusLabel,
  stackLine,
} from "../lib/content";

const featuredProjects = await getFeaturedProjects();
const latestPosts = await getLatestPosts(3);
---

<Base
  title="Willy W. | AI-Native Builder"
  description="I build real systems with AI as a one-person engineering team."
>
  <div class="hero" aria-labelledby="hero-title">
    <p class="kicker">whoami</p>
    <h1 id="hero-title">
      I build real systems with AI &mdash; <em>as a one-person engineering team.</em>
    </h1>
    <p>
      Trading bots, research pipelines, and automation: designed, built, and shipped by
      orchestrating Claude, Codex, and Obsidian. Not a traditional developer, just proof of
      what one motivated person can ship with today's AI tools.
    </p>
    <div class="cta">
      <a class="btn btn-primary" href="/projects">See my projects</a>
      <a class="btn btn-ghost" href="/about">How I work with AI &rarr;</a>
    </div>
  </div>

  <section aria-labelledby="projects-title">
    <div class="sec-head">
      <h2 id="projects-title">Active projects</h2>
      <a href="/projects">all &rarr;</a>
    </div>
    <div class="cards">
      {
        featuredProjects.map((project) => (
          <a class="card" href={`/projects/${project.id}/`}>
            <span class={`chip ${project.data.status}`}>{projectStatusLabel(project)}</span>
            <h3>{project.data.title}</h3>
            <p>{project.data.summary}</p>
            <div class="stack">{stackLine(project.data.stack)}</div>
          </a>
        ))
      }
    </div>
  </section>

  <section aria-labelledby="writing-title">
    <div class="sec-head">
      <h2 id="writing-title">Writing</h2>
      <a href="/blog">all posts &rarr;</a>
    </div>
    <div class="posts">
      {
        latestPosts.map((post) => (
          <div class="post">
            <a href={`/blog/${post.id}/`}>{post.data.title}</a>
            <time datetime={formatMonth(post.data.pubDate)}>{formatMonth(post.data.pubDate)}</time>
          </div>
        ))
      }
    </div>
  </section>

  <section aria-labelledby="toolkit-title">
    <div class="toolkit">
      <div>
        <h3 id="toolkit-title">The AI Toolkit</h3>
        <p>
          The exact stack and division of labor I use, and why it minimizes
          hallucination while maximizing shipping speed.
        </p>
        <div class="pipe">
          claude <span>(architect/review)</span> &rarr; codex <span>(build)</span> &rarr;
          obsidian <span>(memory)</span>
        </div>
      </div>
      <a class="btn btn-ghost" href="/toolkit">Explore &rarr;</a>
    </div>
  </section>
</Base>
