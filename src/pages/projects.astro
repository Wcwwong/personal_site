---
import Base from "../layouts/Base.astro";
import { getProjects, projectStatusLabel, stackLine } from "../lib/content";

const projects = await getProjects();
---

<Base
  title="Portfolio | Willy W."
  description="Portfolio of AI-native systems and project write-ups by Willy W."
>
  <div class="page-hero">
    <p class="kicker">projects</p>
    <h1>Portfolio</h1>
    <p>
      Sanitized project write-ups, kept concrete and evidence-led. Real content will expand in
      Phase C after curation.
    </p>
  </div>

  <section aria-labelledby="project-list-title">
    <div class="sec-head">
      <h2 id="project-list-title">Projects</h2>
    </div>
    <div class="cards">
      {
        projects.map((project) => (
          <a class="card" href={`/projects/${project.id}/`}>
            <span class={`chip ${project.data.status}`}>{projectStatusLabel(project)}</span>
            <h3>{project.data.title}</h3>
            <p>{project.data.summary}</p>
            <div class="stack">{stackLine(project.data.stack)}</div>
          </a>
        ))
      }
    </div>
  </section>
</Base>
